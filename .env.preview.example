 # ─────────────────────────────────────────────────────────────────────────────
  # TFS — Vercel PREVIEW environment variables                                                                          
  #                                                     
  # Set these in: Vercel → Project Settings → Environment Variables                                                     
  # Under "Environment": check PREVIEW only (uncheck Production + Development)                                          
  #                                                                                                                     
  # Differences from production:                                                                                        
  #   • NEXT_PUBLIC_SITE_URL   → your Vercel preview URL                                                                
  #   • Stripe keys            → keep test-mode keys (pk_test_ / sk_test_)                                              
  #   • STRIPE_WEBHOOK_SECRET  → separate webhook endpoint pointing at preview URL
  #   • Everything else        → same values as production are fine                                                     
  # ─────────────────────────────────────────────────────────────────────────────                                       
   
  # ─── Supabase (same project as production is fine for preview) ───────────────                                       
  NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co 
  NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...                                                       
  SUPABASE_SECRET_KEY=sb_secret_...
  SUPABASE_DB_URL=postgres://postgres.your-project:your-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres      
                                                                                                                        
  # ─── Google OAuth ────────────────────────────────────────────────────────────
  # Add your preview URL to the authorised redirect URIs in Google Cloud Console                                        
  GOOGLE_CLIENT_ID=your-google-client-id                                                                                
  GOOGLE_CLIENT_SECRET=your-google-client-secret
                                                                                                                        
  # ─── Stripe (TEST mode — no real charges) ────────────────────────────────────                                       
  NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
  STRIPE_SECRET_KEY=sk_test_...                                                                                         
                                                            
  # Create a SEPARATE webhook in Stripe → Developers → Webhooks
  # pointing to: https://your-preview-url.vercel.app/api/stripe/webhook
  STRIPE_WEBHOOK_SECRET=whsec_...                                                                                       
   
  STRIPE_PRICE_BRONZE=price_...                                                                                         
  STRIPE_PRICE_SILVER=price_...                             
  STRIPE_PRICE_GOLD=price_...                                                                                           
  STRIPE_PRICE_SESSION=price_...
                                                                                                                        
  # ─── Resend ──────────────────────────────────────────────────────────────────
  RESEND_API_KEY=re_...
  RESEND_FROM_EMAIL=noreply@tenantfinancialsolutions.com                                                                
  ADMIN_EMAIL=tenantfinancialsolutions@gmail.com
                                                                                                                        
  # ─── Upstash Redis (optional — no-ops safely if omitted) ────────────────────                                        
  UPSTASH_REDIS_REST_URL=https://...
  UPSTASH_REDIS_REST_TOKEN=...                                                                                          
                                                            
  # ─── Cron ────────────────────────────────────────────────────────────────────                                       
  CRON_SECRET=your-cron-secret
                                                                                                                        
  # ─── Admin emails ─────────────────────────────────────────────────────────────
  ADMIN_EMAILS=markert.wla@gmail.com,mjmfinancialcoaching@gmail.com
                                                                                                                        
  # ─── App — set to your actual Vercel preview URL ─────────────────────────────
  # Vercel → Project → Deployments → click a preview deploy → copy the URL                                              
  NEXT_PUBLIC_SITE_URL=https://your-preview-url.vercel.app                                                              