# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgres://postgres.your-project:your-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ─── Google OAuth (configured in Supabase Dashboard → Auth → Providers → Google) ───
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Stripe ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — create in Stripe Dashboard then paste here
STRIPE_PRICE_BRONZE=price_...
STRIPE_PRICE_SILVER=price_...
STRIPE_PRICE_GOLD=price_...
STRIPE_PRICE_SESSION=price_...

# ─── Resend ──────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@tenantfinancialsolutions.com
ADMIN_EMAIL=tenantfinancialsolutions@gmail.com

# ─── Upstash Redis (rate limiting on auth / booking / contact / codes endpoints) ───
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://tenantfinancialsolutions.com